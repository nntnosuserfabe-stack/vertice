</svg>

<!-- ========== HEADER ========== -->
<header id="top">
  <div class="shell nav">
    <a href="#top" class="brand" aria-label="Vértice — página inicial">
      <svg class="logo" viewBox="0 0 100 100" fill="none" aria-hidden="true">
        <g stroke="url(#g1)" stroke-width="2.4" stroke-linejoin="round">
          <path d="M50 6 L88 32 L74 78 L26 78 L12 32 Z"/>
          <path d="M50 6 L50 50 M88 32 L50 50 M74 78 L50 50 M26 78 L50 50 M12 32 L50 50"/>
        </g>
        <g stroke="#22D3EE" stroke-width="1.6" stroke-dasharray="3 4" opacity=".55">
          <path d="M50 6 L74 78 M50 6 L26 78 M88 32 L12 32 M88 32 L26 78 M12 32 L74 78"/>
        </g>
        <defs><linearGradient id="g1" x1="0" y1="0" x2="100" y2="100">
          <stop offset="0" stop-color="#4F9CF9"/><stop offset="1" stop-color="#22D3EE"/>
        </linearGradient></defs>
      </svg>
