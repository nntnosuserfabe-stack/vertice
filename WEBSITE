</header>

<!-- ========== HERO ========== -->
<section class="hero shell">
  <div class="hero-grid">
    <div class="reveal">
      <span class="eyebrow">Mini desktops corporativos · B2B</span>
      <h1>Máquina lenta é <span class="hl">dinheiro parado</span> na sua empresa.</h1>
      <p class="lead">Cada minuto que o time espera um computador travado é produtividade queimada. A Vértice troca o gargalo por equipamento robusto, com SSD, pronto para anos de operação.</p>
      <div class="hero-cta">
        <a class="btn btn-wa" href="#" data-wa>
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.3A10 10 0 1 0 12 2zm0 18.2a8.2 8.2 0 0 1-4.2-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2zm5.5-6.1c-.3-.2-1.8-.9-2-1s-.5-.2-.7.1-.8 1-1 1.2-.4.2-.7 0a8 8 0 0 1-2.4-1.5 9 9 0 0 1-1.6-2c-.2-.3 0-.5.1-.6l.5-.6.3-.5c.1-.2 0-.4 0-.5L8.8 6.9c-.2-.5-.4-.4-.6-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-1 2.2c0 1.3 1 2.6 1.1 2.8s1.9 2.9 4.6 4c1.7.7 2.3.8 3.1.7.5-.1 1.6-.7 1.8-1.3s.2-1.2.2-1.3-.3-.2-.6-.3z"/></svg>
          Quero destravar minha operação
        </a>
        <a class="btn btn-ghost" href="#produto">Ver o equipamento</a>
      </div>
      <div class="trust-row">
        <div class="t"><b>Sábados</b><span>Instalação sem parar sua operação</span></div>
        <div class="t"><b>Win 11</b><span>Original + nota fiscal</span></div>
        <div class="t"><b>3 meses</b><span>De garantia</span></div>
      </div>
    </div>

    <div class="product-stage">
      <div class="stage-glow"></div>
      <svg class="rig reveal-rig" viewBox="0 0 420 300" fill="none" aria-hidden="true">
        <!-- monitor -->
        <rect x="70" y="30" width="230" height="150" rx="10" fill="#0B1220" stroke="#2A3D63" stroke-width="2"/>
        <rect x="80" y="40" width="210" height="130" rx="5" fill="#070C16"/>
        <!-- boot content -->
        <g class="boot">
          <path d="M175 90 L205 110 L197 145 L153 145 L145 110 Z" stroke="#4F9CF9" stroke-width="1.5" fill="none"/>
          <path d="M175 90 L175 118 M205 110 L175 118 M197 145 L175 118 M153 145 L175 118 M145 110 L175 118" stroke="#22D3EE" stroke-width="1" opacity=".8"/>
          <rect x="120" y="158" width="130" height="4" rx="2" fill="#16233F"/>
          <rect x="120" y="158" width="86" height="4" rx="2" fill="#4F9CF9"/>
        </g>
        <line class="scan" x1="82" y1="52" x2="288" y2="52" stroke="#22D3EE" stroke-width="1" opacity=".5"/>
        <!-- stand -->
        <rect x="175" y="180" width="20" height="22" fill="#1A2740"/>
        <rect x="150" y="200" width="70" height="7" rx="3" fill="#22334F"/>
        <!-- mini pc -->
        <rect x="300" y="120" width="60" height="86" rx="7" fill="#0B1220" stroke="#2A3D63" stroke-width="2"/>
        <circle cx="330" cy="138" r="3" fill="#22D3EE"/>
        <rect x="312" y="152" width="36" height="3" rx="1.5" fill="#16233F"/>
        <rect x="312" y="160" width="36" height="3" rx="1.5" fill="#16233F"/>
        <rect x="312" y="168" width="24" height="3" rx="1.5" fill="#16233F"/>
        <text x="330" y="196" font-family="JetBrains Mono, monospace" font-size="7" fill="#5B6B85" text-anchor="middle">SSD</text>
        <!-- keyboard -->
