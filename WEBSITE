<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vértice — Mini Desktops Corporativos para Empresas</title>
<meta name="description" content="Mini desktops corporativos Dell prontos para o dia a dia da sua empresa. SSD, Windows 11 original, nota fiscal, garantia e instalação sem parar sua operação.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#070B14;
  --surface:#0F1629;
  --navy:#16233F;
  --border:rgba(255,255,255,0.08);
  --border-strong:rgba(255,255,255,0.14);
  --text:#E6EDF7;
  --muted:#8B98B0;
  --accent:#4F9CF9;
  --glow:#22D3EE;
  --wa:#25D366;
  --shell:min(1120px,92vw);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  background:var(--bg);
  color:var(--text);
  font-family:"Instrument Sans",sans-serif;
  line-height:1.6;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
h1,h2,h3,.display{font-family:"Space Grotesk",sans-serif;line-height:1.1;letter-spacing:-0.01em}
.mono{font-family:"JetBrains Mono",monospace}

/* ---------- ambient background ---------- */
.bg-field{position:fixed;inset:0;z-index:-2;pointer-events:none;
  background:
    radial-gradient(60vw 50vh at 70% -10%, rgba(34,211,238,.10), transparent 60%),
    radial-gradient(50vw 50vh at 10% 20%, rgba(79,156,249,.10), transparent 60%),
    var(--bg);
}
.bg-ico{position:fixed;z-index:-1;pointer-events:none;opacity:.14;will-change:transform}
.bg-ico.one{top:8%;right:-60px;width:340px}
.bg-ico.two{bottom:6%;left:-80px;width:420px;opacity:.08}

/* ---------- layout ---------- */
.shell{width:var(--shell);margin-inline:auto}
section{padding:clamp(64px,10vw,120px) 0}
.eyebrow{font-family:"JetBrains Mono",monospace;font-size:.75rem;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);display:inline-flex;align-items:center;gap:.6rem;margin-bottom:1.1rem}
.eyebrow::before{content:"";width:26px;height:1px;background:linear-gradient(90deg,var(--accent),transparent)}

/* ---------- header ---------- */
header{position:fixed;top:0;left:0;right:0;z-index:50;
  padding:16px 0;transition:background .3s,border-color .3s;border-bottom:1px solid transparent}
header.scrolled{background:rgba(7,11,20,.78);backdrop-filter:blur(14px);border-bottom:1px solid var(--border)}
.nav{display:flex;align-items:center;justify-content:space-between}
.brand{display:flex;align-items:center;gap:.7rem;text-decoration:none;color:var(--text)}
.brand .logo{width:34px;height:34px}
.brand .name{font-family:"Space Grotesk",sans-serif;font-weight:700;letter-spacing:.14em;font-size:1.05rem}
.brand .name span{color:var(--muted);font-weight:500;font-size:.7rem;letter-spacing:.16em;display:block;margin-top:-2px}
.nav-links{display:flex;align-items:center;gap:2rem}
.nav-links a{color:var(--muted);text-decoration:none;font-size:.92rem;font-weight:500;transition:color .2s}
.nav-links a:hover{color:var(--text)}

/* ---------- buttons ---------- */
.btn{display:inline-flex;align-items:center;gap:.6rem;font-family:"Space Grotesk",sans-serif;font-weight:600;
  font-size:.98rem;padding:.85rem 1.5rem;border-radius:12px;text-decoration:none;cursor:pointer;border:1px solid transparent;transition:transform .18s,box-shadow .25s,background .2s;white-space:nowrap}
.btn:active{transform:translateY(1px)}
.btn-wa{background:linear-gradient(135deg,#25D366,#128C7E);color:#062012;box-shadow:0 8px 30px rgba(37,211,102,.28)}
.btn-wa:hover{box-shadow:0 10px 40px rgba(37,211,102,.42);transform:translateY(-2px)}
.btn-ghost{background:transparent;border-color:var(--border-strong);color:var(--text)}
.btn-ghost:hover{border-color:var(--accent);color:#fff}
.btn svg{width:19px;height:19px}
.nav .btn{padding:.6rem 1.1rem;font-size:.9rem}

/* ---------- hero ---------- */
.hero{padding-top:clamp(140px,18vh,190px);position:relative}
.hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(32px,5vw,64px);align-items:center}
.hero h1{font-size:clamp(2.4rem,5.4vw,3.9rem);font-weight:700;margin-bottom:1.4rem}
.hero h1 .hl{background:linear-gradient(120deg,var(--accent),var(--glow));-webkit-background-clip:text;background-clip:text;color:transparent}
.hero p.lead{font-size:clamp(1.05rem,1.8vw,1.22rem);color:var(--muted);max-width:38ch;margin-bottom:2rem}
.hero-cta{display:flex;gap:1rem;flex-wrap:wrap;align-items:center}
.trust-row{display:flex;gap:1.5rem;flex-wrap:wrap;margin-top:2.4rem;padding-top:1.6rem;border-top:1px solid var(--border)}
.trust-row .t{display:flex;flex-direction:column;gap:.15rem}
.trust-row .t b{font-family:"Space Grotesk",sans-serif;font-size:1.35rem;color:var(--text)}
.trust-row .t span{font-size:.78rem;color:var(--muted);letter-spacing:.02em}

/* ---------- product visual ---------- */
.product-stage{position:relative;display:flex;align-items:center;justify-content:center;min-height:340px}
.stage-glow{position:absolute;width:78%;height:70%;border-radius:50%;
  background:radial-gradient(circle,rgba(79,156,249,.35),transparent 68%);filter:blur(28px);z-index:0}
.rig{position:relative;z-index:1;width:100%;max-width:430px}
.reveal-rig{opacity:0;transform:translateY(24px) scale(.96)}
.reveal-rig.in{opacity:1;transform:none;transition:opacity .9s ease,transform 1s cubic-bezier(.16,1,.3,1)}
.screen-line{stroke-dasharray:1;stroke-dashoffset:1;animation:none}
.reveal-rig.in .boot{animation:boot 1.1s ease-out .5s forwards;opacity:0}
@keyframes boot{0%{opacity:0}40%{opacity:.4}100%{opacity:1}}
.reveal-rig.in .scan{animation:scan 2.6s ease-in-out 1.4s infinite}
@keyframes scan{0%,100%{transform:translateY(0);opacity:.5}50%{transform:translateY(46px);opacity:.9}}

/* ---------- pains ---------- */
.pains{position:relative}
.pain-head{max-width:56ch;margin-bottom:3rem}
.pain-head h2{font-size:clamp(1.8rem,3.5vw,2.6rem);margin-bottom:1rem}
.pain-head p{color:var(--muted);font-size:1.08rem}
.pain-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem}
.pain-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:1.8rem;position:relative;overflow:hidden;transition:border-color .3s,transform .3s}
.pain-card:hover{border-color:var(--border-strong);transform:translateY(-3px)}
.pain-card .ic{width:42px;height:42px;border-radius:11px;display:grid;place-items:center;background:rgba(79,156,249,.12);border:1px solid rgba(79,156,249,.25);margin-bottom:1.1rem}
.pain-card .ic svg{width:22px;height:22px;stroke:var(--accent)}
.pain-card h3{font-size:1.12rem;margin-bottom:.5rem}
.pain-card p{color:var(--muted);font-size:.95rem}

/* ---------- offer / product ---------- */
.offer{background:linear-gradient(180deg,transparent,rgba(15,22,41,.5),transparent)}
.offer-card{background:linear-gradient(160deg,rgba(22,35,63,.7),rgba(15,22,41,.9));border:1px solid var(--border-strong);
  border-radius:24px;overflow:hidden;display:grid;grid-template-columns:1fr 1fr}
.offer-left{padding:clamp(28px,4vw,48px);border-right:1px solid var(--border)}
.offer-left h2{font-size:clamp(1.6rem,3vw,2.2rem);margin-bottom:.4rem}
.offer-left .sub{color:var(--muted);margin-bottom:1.8rem}
.spec-list{display:flex;flex-direction:column;gap:.1rem;margin-bottom:1.5rem}
.spec-list .row{display:flex;justify-content:space-between;gap:1rem;padding:.7rem 0;border-bottom:1px dashed var(--border)}
.spec-list .row .k{color:var(--muted);font-size:.9rem;font-family:"JetBrains Mono",monospace}
.spec-list .row .v{font-weight:600;font-size:.95rem;text-align:right}
.included{display:flex;flex-wrap:wrap;gap:.5rem}
.chip{font-size:.82rem;padding:.4rem .8rem;border-radius:999px;background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--text)}
.offer-right{padding:clamp(28px,4vw,48px);display:flex;flex-direction:column;justify-content:center}
.price-tier{border:1px solid var(--border);border-radius:16px;padding:1.4rem;margin-bottom:1rem;transition:border-color .3s,background .3s}
.price-tier.featured{border-color:var(--accent);background:rgba(79,156,249,.06);position:relative}
.price-tier.featured::after{content:"Mais escolhido";position:absolute;top:-11px;right:16px;font-size:.68rem;letter-spacing:.12em;
  text-transform:uppercase;background:var(--accent);color:#04121f;padding:.2rem .6rem;border-radius:999px;font-family:"JetBrains Mono",monospace;font-weight:600}
.price-tier .label{font-size:.82rem;color:var(--muted);letter-spacing:.04em;margin-bottom:.35rem}
.price-tier .amount{font-family:"Space Grotesk",sans-serif;font-weight:700;font-size:2rem;display:flex;align-items:baseline;gap:.4rem}
.price-tier .amount .cur{font-size:1rem;color:var(--muted);font-weight:500}
.price-tier .was{font-size:.9rem;color:var(--muted);text-decoration:line-through;margin-left:.4rem}
.price-tier .note{font-size:.86rem;color:var(--muted);margin-top:.4rem}
.offer-right .btn{width:100%;justify-content:center;margin-top:.6rem}

/* ---------- benefits ---------- */
.ben-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.1rem;margin-top:2.5rem}
.ben{display:flex;gap:1rem;padding:1.5rem;background:var(--surface);border:1px solid var(--border);border-radius:14px;transition:border-color .3s}
.ben:hover{border-color:var(--border-strong)}
.ben .ic{flex-shrink:0;width:40px;height:40px;border-radius:10px;display:grid;place-items:center;background:rgba(34,211,238,.1);border:1px solid rgba(34,211,238,.24)}
.ben .ic svg{width:21px;height:21px;stroke:var(--glow)}
.ben h3{font-size:1.05rem;margin-bottom:.3rem}
.ben p{color:var(--muted);font-size:.92rem}

/* ---------- about ---------- */
.about-card{display:grid;grid-template-columns:auto 1fr;gap:clamp(24px,4vw,48px);align-items:center;
  background:var(--surface);border:1px solid var(--border);border-radius:24px;padding:clamp(28px,4vw,48px)}
.avatar{width:130px;height:130px;border-radius:50%;flex-shrink:0;position:relative;overflow:hidden;
  background:linear-gradient(160deg,var(--navy),var(--surface));border:1px solid var(--border-strong);display:grid;place-items:center}
.avatar svg{width:56px;height:56px;stroke:var(--muted)}
.avatar .tag{position:absolute;bottom:8px;left:0;right:0;text-align:center;font-size:.62rem;color:var(--muted);font-family:"JetBrains Mono",monospace;letter-spacing:.05em}
.about-text h2{font-size:clamp(1.5rem,3vw,2rem);margin-bottom:.9rem}
.about-text p{color:var(--muted);margin-bottom:1.2rem;max-width:60ch}
.about-meta{display:flex;flex-direction:column;gap:.5rem;font-size:.92rem}
.about-meta .m{display:flex;gap:.6rem;align-items:center;color:var(--text)}
.about-meta .m svg{width:17px;height:17px;stroke:var(--accent);flex-shrink:0}
.about-meta .m span{color:var(--muted)}
.about-meta a{color:var(--accent);text-decoration:none}
.about-meta a:hover{text-decoration:underline}

/* ---------- final cta ---------- */
.final{text-align:center}
.final-inner{background:linear-gradient(160deg,rgba(22,35,63,.8),rgba(15,22,41,.9));border:1px solid var(--border-strong);
  border-radius:28px;padding:clamp(40px,6vw,72px);position:relative;overflow:hidden}
.final-inner::before{content:"";position:absolute;top:-40%;left:50%;transform:translateX(-50%);width:60%;height:100%;
  background:radial-gradient(circle,rgba(37,211,102,.18),transparent 65%);pointer-events:none}
.final h2{font-size:clamp(1.8rem,4vw,2.8rem);margin-bottom:1rem;position:relative}
.final p{color:var(--muted);font-size:1.1rem;max-width:48ch;margin:0 auto 2rem;position:relative}
.final .btn{position:relative;font-size:1.1rem;padding:1.05rem 2rem}

/* ---------- footer ---------- */
footer{border-top:1px solid var(--border);padding:2.5rem 0;margin-top:2rem}
.foot{display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap}
.foot .brand .name{font-size:.95rem}
.foot p{color:var(--muted);font-size:.85rem}

/* ---------- floating whatsapp ---------- */
.wa-float{position:fixed;bottom:22px;right:22px;z-index:60;width:60px;height:60px;border-radius:50%;
  background:linear-gradient(135deg,#25D366,#128C7E);display:grid;place-items:center;
  box-shadow:0 10px 30px rgba(37,211,102,.4);text-decoration:none;transition:transform .2s}
.wa-float:hover{transform:scale(1.08)}
.wa-float svg{width:30px;height:30px}
.wa-float::after{content:"";position:absolute;inset:0;border-radius:50%;border:2px solid #25D366;animation:ring 2.4s ease-out infinite}
@keyframes ring{0%{transform:scale(1);opacity:.7}100%{transform:scale(1.7);opacity:0}}

/* ---------- reveal ---------- */
.reveal{opacity:0;transform:translateY(28px)}
.reveal.in{opacity:1;transform:none;transition:opacity .7s ease,transform .8s cubic-bezier(.16,1,.3,1)}

/* ---------- responsive ---------- */
@media(max-width:860px){
  .hero-grid{grid-template-columns:1fr;gap:36px}
  .product-stage{order:-1;min-height:260px}
  .nav-links a:not(.btn){display:none}
  .pain-grid{grid-template-columns:1fr}
  .offer-card{grid-template-columns:1fr}
  .offer-left{border-right:none;border-bottom:1px solid var(--border)}
  .ben-grid{grid-template-columns:1fr}
  .about-card{grid-template-columns:1fr;text-align:center;justify-items:center}
  .about-text p{margin-inline:auto}
  .about-meta{align-items:center}
  .bg-ico{display:none}
}
@media(prefers-reduced-motion:reduce){
  *{animation:none!important;transition:none!important}
  .reveal,.reveal-rig{opacity:1!important;transform:none!important}
}
</style>
</head>
